# ── GitHub App ──────────────────────────────────────────────────────────────
# From: https://github.com/settings/apps/<your-app>
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY_PATH=./github-app.pem
# OR base64-encode the PEM and set it inline:
# GITHUB_APP_PRIVATE_KEY_B64=

GITHUB_WEBHOOK_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Database (Neon Postgres) ─────────────────────────────────────────────────
# Format: postgresql+asyncpg://user:pass@host/dbname?sslmode=require
DATABASE_URL=

# ── Redis (Upstash) ──────────────────────────────────────────────────────────
# From: https://console.upstash.com/
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# ── AI (Google Gemini) ───────────────────────────────────────────────────────
# From: https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_DAYS=7

# ── Langfuse ─────────────────────────────────────────────────────────────────
# From: https://cloud.langfuse.com/
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development          # development | staging | production
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
