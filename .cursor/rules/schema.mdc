## Indexes

```sql
CREATE INDEX idx_review_jobs_repo     ON review_jobs(repository_id);
CREATE INDEX idx_review_jobs_status   ON review_jobs(status);
CREATE INDEX idx_reviews_repo         ON reviews(repository_id);
CREATE INDEX idx_reviews_pr           ON reviews(repository_id, pr_number);
CREATE INDEX idx_findings_review      ON findings(review_id);
CREATE INDEX idx_findings_severity    ON findings(severity);
CREATE INDEX idx_embeddings_repo      ON code_embeddings(repository_id, commit_sha);
CREATE INDEX idx_embeddings_vector    ON code_embeddings
  USING ivfflat (embedding vector_cosine_ops) WITH (lists = 100);
```

